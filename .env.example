# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# LLM API keys (set the ones you need)
ANTHROPIC_API_KEY=your_anthropic_key_here
DEEPSEEK_API_KEY=your_deepseek_key_here
OPENAI_API_KEY=your_openai_key_here  # used for Whisper audio transcription

# Model selection per task class (defaults shown)
LLM_MODEL_TRIVIAL=deepseek-chat
LLM_MODEL_STANDARD=deepseek-chat
LLM_MODEL_REASONING=claude-sonnet-4-6
LLM_MODEL_VISION=claude-sonnet-4-6   # must support multimodal

# Budget limits
BUDGET_PER_USER_DAILY_USD=0.10
BUDGET_GLOBAL_HOURLY_USD=1.00

# Database (SQLite default; swap to Postgres for prod)
DATABASE_URL=sqlite+aiosqlite:///./diet.db

# Environment
ENV=dev
